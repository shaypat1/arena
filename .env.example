# Database
DATABASE_URL=postgresql://arena:arena_dev@localhost:5432/arena

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=arena
S3_SECRET_KEY=arena_dev_key
S3_BUCKET=arena-frames

# Crypto Hot Wallets (NEVER commit real keys)
